{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://thefairmap-production.up.railway.app/api/:path*" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/embed", "destination": "/embed.html" },
    { "source": "/signup", "destination": "/signup.html" },
    { "source": "/map", "destination": "/map.html" },
    { "source": "/platform/login", "destination": "/vendor-login.html" },
    { "source": "/vendor-login", "destination": "/vendor-login.html" },
    { "source": "/vendors/login", "destination": "/vendor-login.html" },
    { "source": "/vendors/dashboard", "destination": "/vendor-dash.html" },
    { "source": "/vendors/claim", "destination": "/vendor-claim.html" },
    { "source": "/platform", "destination": "/platform.html" },
    { "source": "/analytics", "destination": "/analytics.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
